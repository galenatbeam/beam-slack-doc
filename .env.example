SLACK_SIGNING_SECRET=your-signing-secret
SLACK_BOT_TOKEN=xoxb-your-bot-token
SLACK_APP_TOKEN=xapp-your-app-level-token

# OpenAI-hosted mode (optional when using LLM_BASE_URL for local mode)
OPENAI_API_KEY=your-openai-key
OPENAI_MODEL=gpt-4.1-mini

# Atlassian MCP auth (required)
ATLASSIAN_EMAIL=you@example.com
CONFLUENCE_MCP_API_KEY=your-atlassian-personal-api-token
ATLASSIAN_CLOUD_ID=your-atlassian-cloud-id

# Optional MCP / search config
CONFLUENCE_SPACE=YOURSPACE
MCP_SERVER_NAME=atlassian-rovo
MCP_SERVER_URL=https://mcp.atlassian.com/v1/mcp

# Optional local LLM mode
# LLM_BASE_URL=http://localhost:11434/v1

# Optional debug logging (redacted)
# AGENTIC_SEARCH_DEBUG=1